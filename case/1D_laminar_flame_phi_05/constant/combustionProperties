// Properties file for SDR model

ignite              yes;

FGMModel            FGMModel; 

PDModel             mixAvg; // mixAvg or Lewis

betacDynamic        no; //Static or dynamic computation of the combustion model parameter

betaC               betacVal [0 0 0 0 0 0 0] 6.5; //Value of static betac 

